            const userVal = input.value.trim().toLowerCase();
            const expectedVal = expectedEn.toLowerCase();
            
            input.disabled = true;
            btn.disabled = true;
            
            let feedbackHtml = `<div style="text-align: left; background: #E8F0FE; padding: 20px; border-radius: 12px; border-left: 6px solid var(--goku-primary); box-shadow: 0 4px 6px rgba(0,0,0,0.02); margin-top: 15px;">`;
            
            if(userVal === expectedVal || userVal.includes(expectedVal)) {
                feedbackHtml += `<span style="color: #10B981; font-weight: 800; font-size: 1.3rem; display: block; margin-bottom: 8px;">Correct!</span>`;
            } else {
                feedbackHtml += `<span style="color: #64748B; font-size: 1.2rem; display: block; margin-bottom: 8px;">Expected Answer:</span>`;
            }
            
            feedbackHtml += `<strong style="color: var(--goku-primary); font-size: 1.6rem; letter-spacing: 0.5px;">${expectedEn}</strong>`;
            if (expectedPa) {
                feedbackHtml += `<br><span class="punjabi-block" style="margin-top: 8px; font-weight: 500; font-size: 1.3rem;">${expectedPa}</span>`;
            }
            feedbackHtml += `</div>`;
            
            feedback.innerHTML = feedbackHtml;
            if(nextBtn) nextBtn.style.display = 'block';
        }

        function nextSubSlide(containerId, nextIndex) {
            const container = document.getElementById(containerId);
            const subSlides = container.querySelectorAll('.sub-slide');
            subSlides.forEach(s => s.classList.remove('active'));
            const nextSlide = container.querySelector('#' + containerId + '-s' + nextIndex);
            if(nextSlide) nextSlide.classList.add('active');
        }

        // Global Keyboard & Touch Nav
        document.addEventListener('keydown', (e) => {
            if (document.activeElement.tagName === 'INPUT') return;
            if (e.key === 'ArrowRight') moveSlide(1);
            else if (e.key === 'ArrowLeft') moveSlide(-1);
        });

        let touchStartX = 0;
        let touchEndX = 0;
        document.addEventListener('touchstart', e => { touchStartX = e.changedTouches[0].screenX; });
        document.addEventListener('touchend', e => { 
            touchEndX = e.changedTouches[0].screenX; 
            if(e.target.closest('.sub-slider-container') || e.target.closest('.match-grid') || e.target.closest('.cloze-paragraph')) return;
            if (touchEndX < touchStartX - 50) moveSlide(1); 
            if (touchEndX > touchStartX + 50) moveSlide(-1); 
        });

        // The Transition Reset Loop
        slider.addEventListener('transitionend', () => {
            slides.forEach((slide, index) => {
                if (index !== currentSlide) {
                    // Reset Cloze
                    slide.querySelectorAll('.cloze-blank').forEach(b => {
                        b.classList.remove('revealed');
                        b.innerText = '';
                    });
                    
                    // Reset Match
                    slide.querySelectorAll('.match-btn').forEach(b => {
                        b.classList.remove('selected', 'matched', 'error');
                        b.style.pointerEvents = 'auto';
                        // Remove checkmark
                        b.innerHTML = b.innerHTML.replace(' ✅', '');
                    });
                    slide.querySelectorAll('.completion-msg').forEach(m => m.remove());
                    firstSelection = null;

                    // Reset Sequencer
                    slide.querySelectorAll('.sequencer-container').forEach(c => {
                        c.querySelectorAll('.seq-step').forEach((s, i) => {
                            if(i !== 0) s.classList.remove('visible'); // Keep step 1 visible
                            s.classList.remove('arrow-visible');
                        });
                        const seqBtn = c.querySelector('.seq-btn');
                        if(seqBtn) seqBtn.style.display = 'block';
                    });

                    // Reset Standard Quizzes
                    slide.querySelectorAll('.sub-slider-container').forEach(container => {
                        if(!container.classList.contains('sequencer-container')) {
                            const subSlides = container.querySelectorAll('.sub-slide');
                            subSlides.forEach((s, i) => {
                                if(i === 0) s.classList.add('active');
                                else s.classList.remove('active');
                            });
                            
                            const btns = container.querySelectorAll('.option-btn');
                            btns.forEach(b => {
                                b.disabled = false;
                                b.classList.remove('correct', 'incorrect');
                            });

                            const inputs = container.querySelectorAll('.sa-input');
                            inputs.forEach(input => {
                                input.value = '';
                                input.disabled = false;
                            });
                            const saBtns = container.querySelectorAll('.sa-submit-btn');
                            saBtns.forEach(btn => btn.disabled = false);

                            const feedbacks = container.querySelectorAll('.feedback');
                            feedbacks.forEach(f => f.innerHTML = '');
                            const nextBtns = container.querySelectorAll('.next-sub-btn');
                            nextBtns.forEach(nb => nb.style.display = 'none');
                        }
                    });
                }
            });
        });
        
        // Bilingual Anki Export
        function exportToAnki() {
            let csvData = "";
            const saCards = document.querySelectorAll('.short-answer');
            if(saCards.length === 0) {
                alert("No Anki flashcards found in this version.");
                return;
            }
            saCards.forEach(card => {
                const q = card.getAttribute('data-q').replace(/"/g, '""');
                let aEn = card.getAttribute('data-a').replace(/"/g, '""');
                let aPa = card.getAttribute('data-pa') || "";
                
                let fullAnswer = aEn;
                if(aPa !== "") {
                    fullAnswer += ` <br><br><span style='color:#64748B;'>${aPa}</span>`;
                }
                
                csvData += `"${q}","${fullAnswer}"\n`;
            });
            const blob = new Blob(['\uFEFF' + csvData], { type: 'text/csv;charset=utf-8;' });
            const link = document.createElement("a");
            const url = URL.createObjectURL(blob);
            link.setAttribute("href", url);
            link.setAttribute("download", "Class10_Science_Phase1_Premium_Anki.csv");
            link.style.visibility = 'hidden';
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        }

        updateUI();
    </script>
</body>

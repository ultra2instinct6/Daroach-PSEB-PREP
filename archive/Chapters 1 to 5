    <script>
    document.addEventListener("DOMContentLoaded", () => {
        let currentSlide = 0;
        const slides = document.querySelectorAll('.slide');
        const totalSlides = slides.length;
        const slider = document.getElementById('slider');
        const prevBtn = document.getElementById('prevBtn');
        const nextBtn = document.getElementById('nextBtn');
        const progressBar = document.getElementById('progress-bar');
        const counter = document.getElementById('counter');

        function updateUI() {
            slider.style.transform = `translateX(-${currentSlide * 100}%)`;
            
            slides.forEach((slide, index) => {
                if (index === currentSlide) {
                    slide.classList.add('active');
                } else {
                    slide.classList.remove('active');
                }
            });

            prevBtn.disabled = currentSlide === 0;
            nextBtn.disabled = currentSlide === totalSlides - 1;

            const progress = ((currentSlide + 1) / totalSlides) * 100;
            progressBar.style.width = `${progress}%`;

            counter.innerText = `${currentSlide + 1} / ${totalSlides}`;
        }

        window.moveSlide = function(direction) {
            currentSlide += direction;
            if (currentSlide < 0) currentSlide = 0;
            if (currentSlide >= totalSlides) currentSlide = totalSlides - 1;
            updateUI();
        }
        
        window.goToSlide = function(index) {
            currentSlide = index;
            if (currentSlide < 0) currentSlide = 0;
            if (currentSlide >= totalSlides) currentSlide = totalSlides - 1;
            updateUI();
        }
        
        window.jumpToChapter = function(chId) {
            const el = document.getElementById(chId);
            if(el) {
                const index = Array.from(slides).indexOf(el);
                if(index !== -1) window.goToSlide(index);
            }
        }
        
        window.promptSlide = function() {
            const numStr = prompt(`Enter a slide number (1 to ${totalSlides}):`);
            if (numStr !== null) {
                const num = parseInt(numStr, 10);
                if (!isNaN(num) && num >= 1 && num <= totalSlides) {
                    window.goToSlide(num - 1);
                } else {
                    alert("Invalid slide number.");
                }
            }
        }

        window.checkAnswer = function(btn, isCorrect, isMCQ) {
            const qDiv = btn.closest('.sub-slide');
            const feedback = qDiv.querySelector('.feedback');
            const nextBtn = qDiv.querySelector('.next-sub-btn');
            const buttons = qDiv.querySelectorAll('.option-btn');

            buttons.forEach(b => b.disabled = true); 
            
            if (isCorrect) {
                btn.classList.add('correct');
                feedback.innerHTML = "<span style='color: #10B981; font-weight: bold;'>Correct! (ਸਹੀ)</span>";
            } else {
                btn.classList.add('incorrect');
                feedback.innerHTML = "<span style='color: #EF4444; font-weight: bold;'>Incorrect (ਗਲਤ).</span>";
                if(isMCQ) {
                    const correctBtn = qDiv.querySelector('[data-correct="true"]');
                    if(correctBtn) correctBtn.classList.add('correct');
                }
            }
            
            if(nextBtn) nextBtn.style.display = 'block';
        }

        window.checkSA = function(btn, expectedEn, expectedPa) {
            const qDiv = btn.closest('.sub-slide');
            const input = qDiv.querySelector('.sa-input');
            const feedback = qDiv.querySelector('.feedback');
            const nextBtn = qDiv.querySelector('.next-sub-btn');
            
            const userVal = input.value.trim().toLowerCase();
            const expectedVal = expectedEn.toLowerCase();
            
            input.disabled = true;
            btn.disabled = true;
            
            let feedbackHtml = `<div style="text-align: left; background: #E8F0FE; padding: 15px; border-radius: 8px; border-left: 5px solid var(--goku-blue);">`;
            
            if(userVal === expectedVal) {
                feedbackHtml += `<span style="color: #10B981; font-weight: bold; font-size: 1.2rem;">Correct!</span><br>`;
            } else {
                feedbackHtml += `<span style="color: #555; font-size: 1.1rem;">Expected Answer:</span><br>`;
            }
            
            feedbackHtml += `<strong style="color: var(--goku-blue); font-size: 1.4rem;">${expectedEn}</strong>`;
            if (expectedPa) {
                feedbackHtml += `<br><span class="punjabi-block" style="margin-top: 5px; font-weight: bold;">${expectedPa}</span>`;
            }
            feedbackHtml += `</div>`;
            
            feedback.innerHTML = feedbackHtml;
            if(nextBtn) nextBtn.style.display = 'block';
        }

        window.nextSubSlide = function(containerId, nextIndex) {
            const container = document.getElementById(containerId);
            const subSlides = container.querySelectorAll('.sub-slide');
            subSlides.forEach(s => s.classList.remove('active'));
            const nextSlide = container.querySelector('#' + containerId + '-s' + nextIndex);
            if(nextSlide) nextSlide.classList.add('active');
        }

        /* TEXT-TO-SPEECH WITH UI FEEDBACK & CHROME FIX */
        window.activeReadBtn = null;
        
        window.speakWord = function(text, btn) {
            if ('speechSynthesis' in window) {
                window.speechSynthesis.cancel();
                window.speechSynthesis.resume();
                const utterance = new SpeechSynthesisUtterance(text);
                utterance.lang = 'en-US';
                utterance.rate = 0.85; 
                if(btn) {
                    btn.style.backgroundColor = '#D1FAE5'; 
                    utterance.onend = () => { btn.style.backgroundColor = ''; };
                    utterance.onerror = () => { btn.style.backgroundColor = ''; };
                }
                window.speechSynthesis.speak(utterance);
            } else {
                alert("Text-to-speech is not supported in this browser.");
            }
        }
        
        window.speakPassage = function(textId, btn) {
            if ('speechSynthesis' in window) {
                window.speechSynthesis.cancel();
                window.speechSynthesis.resume();
                
                if(window.activeReadBtn) {
                    window.activeReadBtn.innerHTML = '▶️ Read to Me';
                    window.activeReadBtn.style.background = '';
                }
                
                const textElement = document.getElementById(textId);
                const text = textElement.innerText || textElement.textContent;
                
                const sentences = (text.match(/[^.!?]+[.!?]*/g) || [text])
                                    .map(s => s.trim())
                                    .filter(s => s.length > 0);
                
                if(sentences.length === 0) return;

                window.activeReadBtn = btn;
                btn.innerHTML = '🔊 Reading...';
                btn.style.background = 'var(--goku-orange)';
                
                let currentSentence = 0;
                
                function speakNext() {
                    if (currentSentence < sentences.length) {
                        const utterance = new SpeechSynthesisUtterance(sentences[currentSentence]);
                        utterance.lang = 'en-US';
                        utterance.rate = 0.85;
                        
                        utterance.onend = function() {
                            currentSentence++;
                            speakNext();
                        };
                        
                        utterance.onerror = function(e) {
                            console.error("TTS Error:", e);
                            window.stopSpeaking();
                        };
                        
                        window.speechSynthesis.speak(utterance);
                    } else {
                        window.stopSpeaking();
                    }
                }
                
                speakNext();
                
            } else {
                alert("Text-to-speech is not supported in this browser.");
            }
        }
        
        window.stopSpeaking = function() {
            if ('speechSynthesis' in window) {
                window.speechSynthesis.cancel();
                if(window.activeReadBtn) {
                    window.activeReadBtn.innerHTML = '▶️ Read to Me';
                    window.activeReadBtn.style.background = '';
                    window.activeReadBtn = null;
                }
            }
        }

        /* SIMULATOR 5: DISPLACEMENT PREDICTOR */
        const reactivity = { 'K': 14, 'Na': 13, 'Ca': 12, 'Mg': 11, 'Al': 10, 'Zn': 9, 'Fe': 8, 'Pb': 7, 'H': 6, 'Cu': 5, 'Ag': 4, 'Au': 3 };
        window.predictDisplacement = function() {
            const m1 = document.getElementById('solid-metal').value;
            const m2 = document.getElementById('aqueous-salt').value;
            const res = document.getElementById('displacement-result');
            
            const v1 = reactivity[m1];
            const v2 = reactivity[m2];
            
            const nameMap = {'K':'Potassium', 'Na':'Sodium', 'Ca':'Calcium', 'Mg':'Magnesium', 'Al':'Aluminum', 'Zn':'Zinc', 'Fe':'Iron', 'Pb':'Lead', 'Cu':'Copper', 'Ag':'Silver'};
            
            if(m1 === m2) {
                res.innerHTML = "<span style='color:#555;'>No reaction. Same metal!</span>";
            } else if (v1 > v2) {
                res.innerHTML = `<span style='color:#10B981;'>Reaction Occurs! ✅<br><span style='font-size:1.4rem; font-weight:normal;'>${nameMap[m1]} is more reactive, so it displaces ${nameMap[m2]}.</span></span>`;
            } else {
                res.innerHTML = `<span style='color:#EF4444;'>No Reaction ❌<br><span style='font-size:1.4rem; font-weight:normal;'>${nameMap[m1]} is less reactive than ${nameMap[m2]}. It cannot displace it.</span></span>`;
            }
        };

        /* SIMULATOR 6: ALKANE BUILDER */
        const alkanes = ['-', 'Methane', 'Ethane', 'Propane', 'Butane', 'Pentane', 'Hexane'];
        window.buildAlkane = function() {
            const n = parseInt(document.getElementById('alkane-slider').value);
            document.getElementById('alkane-name').innerText = alkanes[n];
            const h = (2 * n) + 2;
            
            // Format subscript for formula
            const subN = n > 1 ? `<sub>${n}</sub>` : '';
            const subH = `<sub>${h}</sub>`;
            document.getElementById('alkane-formula').innerHTML = `C${subN}H${subH}`;
            
            // Draw structure text
            let tops = '   ' + ' H  '.repeat(n) + '\n   ' + ' |  '.repeat(n) + '\n';
            let mid = 'H--' + 'C--'.repeat(n) + 'H\n';
            let bots = '   ' + ' |  '.repeat(n) + '\n   ' + ' H  '.repeat(n);
            
            document.getElementById('alkane-structure').innerText = tops + mid + bots;
        };

        /* SIMULATOR 1: BALANCING */
        window.calcBalance = function() {
            const fe = parseInt(document.getElementById('c-fe').value) || 0;
            const h2o = parseInt(document.getElementById('c-h2o').value) || 0;
            const fe3o4 = parseInt(document.getElementById('c-fe3o4').value) || 0;
            const h2 = parseInt(document.getElementById('c-h2').value) || 0;
            
            const lFe = fe * 1; const lH = h2o * 2; const lO = h2o * 1;
            const rFe = fe3o4 * 3; const rH = h2 * 2; const rO = fe3o4 * 4;
            
            document.getElementById('lhs-fe').innerText = lFe;
            document.getElementById('lhs-h').innerText = lH;
            document.getElementById('lhs-o').innerText = lO;
            document.getElementById('rhs-fe').innerText = rFe;
            document.getElementById('rhs-h').innerText = rH;
            document.getElementById('rhs-o').innerText = rO;
            
            const status = document.getElementById('balance-status');
            if(lFe === rFe && lH === rH && lO === rO && lFe > 0) {
                status.className = 'balance-status status-balanced';
                status.innerText = 'Equation is BALANCED! ✅';
            } else {
                status.className = 'balance-status status-unbalanced';
                status.innerText = 'Equation is UNBALANCED ❌';
            }
        }
        
        /* SIMULATOR 2: pH MAPPING */
        window.mapPh = function(val, name) {
            const pointer = document.getElementById('ph-pointer');
            const percent = (val / 14) * 100;
            pointer.style.left = `${percent}%`;
            pointer.setAttribute('data-val', `${name} (${val})`);
        }
        
        /* SIMULATOR 3: BOHR MODEL */
        const elementsData = [
            {n:1, sym:'H', conf:[1]}, {n:2, sym:'He', conf:[2]}, {n:3, sym:'Li', conf:[2,1]}, {n:4, sym:'Be', conf:[2,2]}, {n:5, sym:'B', conf:[2,3]},
            {n:6, sym:'C', conf:[2,4]}, {n:7, sym:'N', conf:[2,5]}, {n:8, sym:'O', conf:[2,6]}, {n:9, sym:'F', conf:[2,7]}, {n:10, sym:'Ne', conf:[2,8]},
            {n:11, sym:'Na', conf:[2,8,1]}, {n:12, sym:'Mg', conf:[2,8,2]}, {n:13, sym:'Al', conf:[2,8,3]}, {n:14, sym:'Si', conf:[2,8,4]}, {n:15, sym:'P', conf:[2,8,5]},
            {n:16, sym:'S', conf:[2,8,6]}, {n:17, sym:'Cl', conf:[2,8,7]}, {n:18, sym:'Ar', conf:[2,8,8]}, {n:19, sym:'K', conf:[2,8,8,1]}, {n:20, sym:'Ca', conf:[2,8,8,2]}
        ];
        
        function buildBohrButtons() {
            const container = document.getElementById('bohr-buttons');
            if(!container) return;
            let html = '';
            elementsData.forEach((el, index) => {
                html += `<div class="element-btn" onclick="drawBohr(${index}, this)"><strong>${el.sym}</strong><span>${el.n}</span></div>`;
            });
            container.innerHTML = html;
        }
        
        window.drawBohr = function(index, btnEl) {
            document.querySelectorAll('.element-btn').forEach(b => b.classList.remove('active'));
            if(btnEl) btnEl.classList.add('active');
            
            const el = elementsData[index];
            document.getElementById('bohr-name').innerText = `${el.sym} (Atomic No. ${el.n})`;
            document.getElementById('bohr-conf').innerText = `Configuration: [${el.conf.join(', ')}]`;
            
            const svgCont = document.getElementById('bohr-svg-container');
            let svg = '<svg width="200" height="200" viewBox="0 0 200 200">';
            svg += '<circle cx="100" cy="100" r="12" class="nucleus"/>';
            svg += `<text x="100" y="104" font-size="10" fill="white" text-anchor="middle" font-weight="bold">${el.sym}</text>`;
            
            const radii = [35, 60, 85, 105];
            for(let i=0; i<el.conf.length; i++) {
                let r = radii[i];
                svg += `<circle cx="100" cy="100" r="${r}" class="orbit"/>`;
                let num_e = el.conf[i];
                for(let j=0; j<num_e; j++) {
                    let angle = (j / num_e) * Math.PI * 2;
                    let x = 100 + r * Math.cos(angle);
                    let y = 100 + r * Math.sin(angle);
                    svg += `<circle cx="${x}" cy="${y}" r="4" class="electron" style="animation-delay: -${j}s"/>`;
                }
            }
            svg += '</svg>';
            svgCont.innerHTML = svg;
        }

        document.addEventListener('keydown', (e) => {
            if (document.activeElement.tagName === 'INPUT') return;
            if (e.key === 'ArrowRight') window.moveSlide(1);
            else if (e.key === 'ArrowLeft') window.moveSlide(-1);
        });

        let touchStartX = 0;
        let touchStartY = 0;
        let touchEndX = 0;
        let touchEndY = 0;
        
        document.addEventListener('touchstart', e => { 
            touchStartX = e.changedTouches[0].screenX; 
            touchStartY = e.changedTouches[0].screenY; 
        }, {passive: true});
        
        document.addEventListener('touchend', e => { 
            touchEndX = e.changedTouches[0].screenX; 
            touchEndY = e.changedTouches[0].screenY; 
            
            // Don't swipe if the user is scrolling vertically
            if(Math.abs(touchEndY - touchStartY) > Math.abs(touchEndX - touchStartX)) return;
            
            if(e.target.closest('.sub-slider-container') || e.target.closest('.balancer-panel') || e.target.closest('.ph-tool') || e.target.closest('.bohr-app') || e.target.closest('.reading-box')) return;
            
            if (touchEndX < touchStartX - 50) window.moveSlide(1); 
            if (touchEndX > touchStartX + 50) window.moveSlide(-1); 
        });

        slider.addEventListener('transitionend', (e) => {
            if (e.target !== slider || e.propertyName !== 'transform') return;
            if(window.stopSpeaking) window.stopSpeaking();
            slides.forEach((slide, index) => {
                if (index !== currentSlide) {
                    const subContainers = slide.querySelectorAll('.sub-slider-container');
                    subContainers.forEach(container => {
                        const subSlides = container.querySelectorAll('.sub-slide');
                        subSlides.forEach((s, i) => {
                            if(i === 0) s.classList.add('active');
                            else s.classList.remove('active');
                        });
                        
                        const btns = container.querySelectorAll('.option-btn');
                        btns.forEach(b => {
                            b.disabled = false;
                            b.classList.remove('correct', 'incorrect');
                        });

                        const inputs = container.querySelectorAll('.sa-input');
                        inputs.forEach(input => {
                            input.value = '';
                            input.disabled = false;
                        });
                        const saBtns = container.querySelectorAll('.sa-submit-btn');
                        saBtns.forEach(btn => btn.disabled = false);

                        const feedbacks = container.querySelectorAll('.feedback');
                        feedbacks.forEach(f => f.innerHTML = '');
                        const nextBtns = container.querySelectorAll('.next-sub-btn');
                        nextBtns.forEach(nb => nb.style.display = 'none');
                    });
                }
            });
        });
        
        window.exportToAnki = function() {
            let csvData = "";
            const saCards = document.querySelectorAll('.short-answer');
            saCards.forEach(card => {
                const q = card.getAttribute('data-q').replace(/"/g, '""');
                const a = card.getAttribute('data-a').replace(/"/g, '""');
                csvData += `"${q}","${a}"\n`;
            });
            const blob = new Blob(['\uFEFF' + csvData], { type: 'text/csv;charset=utf-8;' });
            const link = document.createElement("a");
            const url = URL.createObjectURL(blob);
            link.setAttribute("href", url);
            link.setAttribute("download", "Class10_Science_PSEB_Final_Deck.csv");
            link.style.visibility = 'hidden';
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        }

        buildBohrButtons();
        updateUI();
    });
    </script>
</body>
</html>
fication" data-pa="ਜੈਵਿਕ ਵਾਧਾ"><div class="sub-progress">Short Answer 4 of 5</div><div class="question-text">What is the buildup of toxins in a food chain called?</div><input type="text" class="sa-input" placeholder="Type your answer..."><button class="sa-submit-btn" onclick="checkSA(this, 'Biological magnification', 'ਜੈਵਿਕ ਵਾਧਾ')">Check Answer</button><div class="feedback"></div><button class="next-sub-btn" onclick="nextSubSlide('sib-ch13', 5)">Next Question &rarr;</button></div><div class="sub-slide short-answer" id="sib-ch13-s5" data-q="Waste that can be broken down naturally is called?" data-a="Biodegradable" data-pa="ਜੈਵ-ਵਿਘਟਨਸ਼ੀਲ"><div class="sub-progress">Short Answer 5 of 5</div><div class="question-text">Waste that can be broken down naturally is called?</div><input type="text" class="sa-input" placeholder="Type your answer..."><button class="sa-submit-btn" onclick="checkSA(this, 'Biodegradable', 'ਜੈਵ-ਵਿਘਟਨਸ਼ੀਲ')">Check Answer</button><div class="feedback"></div><button class="next-sub-btn" onclick="document.getElementById('nextBtn').click()">Start Quick Check &rarr;</button></div></div></div></div>
<div class="slide"><div class="content-box"><h2>Quick Check: Chapter 13 <span class="punjabi">(ਤੁਰੰਤ ਜਾਂਚ)</span></h2><div class="sub-slider-container" id="mcq-ch13"><div class="sub-slide active" id="mcq-ch13-s1"><div class="sub-progress">Question 1 of 5</div><div class="question-text">Which of the following describes the flow of energy in an ecosystem?</div><button class="option-btn" data-correct="true" onclick="checkAnswer(this, true, true)">A. Unidirectional</button><button class="option-btn" onclick="checkAnswer(this, false, true)">B. Bidirectional</button><button class="option-btn" onclick="checkAnswer(this, false, true)">C. Cyclic</button><div class="feedback"></div><button class="next-sub-btn" onclick="nextSubSlide('mcq-ch13', 2)">Next Question &rarr;</button></div><div class="sub-slide" id="mcq-ch13-s2"><div class="sub-progress">Question 2 of 5</div><div class="question-text">The depletion of the ozone layer is mainly due to:</div><button class="option-btn" data-correct="true" onclick="checkAnswer(this, true, true)">A. Chlorofluorocarbons (CFCs)</button><button class="option-btn" onclick="checkAnswer(this, false, true)">B. Carbon dioxide</button><button class="option-btn" onclick="checkAnswer(this, false, true)">C. Methane gas</button><div class="feedback"></div><button class="next-sub-btn" onclick="nextSubSlide('mcq-ch13', 3)">Next Question &rarr;</button></div><div class="sub-slide" id="mcq-ch13-s3"><div class="sub-progress">Question 3 of 5</div><div class="question-text">In a food chain, the third trophic level is always occupied by:</div><button class="option-btn" onclick="checkAnswer(this, false, true)">A. Herbivores</button><button class="option-btn" data-correct="true" onclick="checkAnswer(this, true, true)">B. Carnivores</button><button class="option-btn" onclick="checkAnswer(this, false, true)">C. Producers</button><div class="feedback"></div><button class="next-sub-btn" onclick="nextSubSlide('mcq-ch13', 4)">Next Question &rarr;</button></div><div class="sub-slide" id="mcq-ch13-s4"><div class="sub-progress">Question 4 of 5</div><div class="question-text">Ozone layer protects us from:</div><button class="option-btn" onclick="checkAnswer(this, false, true)">A. Visible light</button><button class="option-btn" data-correct="true" onclick="checkAnswer(this, true, true)">B. Ultraviolet (UV) rays</button><button class="option-btn" onclick="checkAnswer(this, false, true)">C. Infrared rays</button><div class="feedback"></div><button class="next-sub-btn" onclick="nextSubSlide('mcq-ch13', 5)">Next Question &rarr;</button></div><div class="sub-slide" id="mcq-ch13-s5"><div class="sub-progress">Question 5 of 5</div><div class="question-text">Biological magnification leads to maximum toxin concentration in:</div><button class="option-btn" onclick="checkAnswer(this, false, true)">A. Primary consumers</button><button class="option-btn" onclick="checkAnswer(this, false, true)">B. Producers</button><button class="option-btn" data-correct="true" onclick="checkAnswer(this, true, true)">C. Top carnivores (Humans)</button><div class="feedback"></div><button class="next-sub-btn" onclick="document.getElementById('nextBtn').click()">Finish Phase 2 &rarr;</button></div></div></div></div>

        <!-- END SLIDE / ANKI EXPORT -->
        <div class="slide" id="anki">
            <div class="content-box title-slide" style="border-top: 10px solid var(--goku-accent) !important; border-bottom: 10px solid var(--goku-primary) !important;">
                <h2>Download Your Bilingual Flashcards <span class="punjabi">(ਫਲੈਸ਼ਕਾਰਡ ਡਾਊਨਲੋਡ ਕਰੋ)</span></h2>
                <p style="text-align: left;">Every single "Say It Back" question in this deck has been automatically formatted for Anki. The back of each card will now display both the English and Punjabi answers. <span class="punjabi-block">(ਇਸ ਡੈੱਕ ਵਿੱਚ ਹਰ "Say It Back" ਸਵਾਲ ਅੰਕੀ ਲਈ ਤਿਆਰ ਹੈ।)</span></p>
                <ol style="text-align: left; margin-top: 20px; font-size: 1.2rem; background: #F8FAFC; padding: 25px 25px 25px 45px; border-radius: 12px; border: 1px solid #E2E8F0;">
                    <li><strong>Click</strong> the button below to generate your .csv file.</li>
                    <li><strong>Open</strong> the Anki App on your computer.</li>
                    <li><strong>Click</strong> "Import File" and select the downloaded file.</li>
                </ol>
                <button class="export-btn" onclick="exportToAnki()">Export to Anki (Bilingual CSV)</button>
            </div>
        </div>

    </div>

    <script>
        // SLIDER NAVIGATION
        let currentSlide = 0;
        const slides = document.querySelectorAll('.slide');
        const totalSlides = slides.length;
        const slider = document.getElementById('slider');
        const prevBtn = document.getElementById('prevBtn');
        const nextBtn = document.getElementById('nextBtn');
        const progressBar = document.getElementById('progress-bar');
        const counter = document.getElementById('counter');

        function updateUI() {
            slider.style.transform = `translateX(-${currentSlide * 100}%)`;
            slides.forEach((slide, index) => {
                if (index === currentSlide) slide.classList.add('active');
                else slide.classList.remove('active');
            });
            prevBtn.disabled = currentSlide === 0;
            nextBtn.disabled = currentSlide === totalSlides - 1;
            progressBar.style.width = `${((currentSlide + 1) / totalSlides) * 100}%`;
            if(counter) counter.innerText = `${currentSlide + 1} / ${totalSlides}`;
        }

        function moveSlide(direction) {
            currentSlide += direction;
            if (currentSlide < 0) currentSlide = 0;
            if (currentSlide >= totalSlides) currentSlide = totalSlides - 1;
            updateUI();
        }

        if(counter) {
            counter.addEventListener('click', () => {
                const target = prompt(`Enter slide number to jump to (1 - ${totalSlides}):`);
                if (target !== null && !isNaN(target)) {
                    let index = parseInt(target) - 1;
                    if (index >= 0 && index < totalSlides) {
                        currentSlide = index;
                        updateUI();
                    } else {
                        alert("Invalid slide number.");
                    }
                }
            });
        }
        
        function jumpToChapter(chapterId) {
            const targetSlide = document.getElementById(chapterId);
            if(targetSlide) {
                const allSlidesArray = Array.from(slides);
                const targetIndex = allSlidesArray.indexOf(targetSlide);
                if(targetIndex !== -1) {
                    currentSlide = targetIndex;
                    updateUI();
                }
            }
        }

        /* --- MODULE 1: ACTIVE RECALL BLANKS JS --- */
        function revealCloze(el) {
            el.classList.add('revealed');
            el.innerText = el.getAttribute('data-ans');
        }

        /* --- MODULE 2: MEMORY MATCH MATRIX JS --- */
        let firstSelection = null;
        function handleMatch(btn) {
            if(btn.classList.contains('matched')) return;
            if(!firstSelection) {
                firstSelection = btn;
                btn.classList.add('selected');
            } else {
                if(btn === firstSelection) {
                    btn.classList.remove('selected');
                    firstSelection = null;
                    return;
                }
                if(firstSelection.dataset.match === btn.dataset.match) {
                    btn.classList.add('matched');
                    btn.classList.remove('selected');
                    firstSelection.classList.remove('selected');
                    firstSelection.classList.add('matched');
                    
                    btn.innerHTML += ' ✅';
                    firstSelection.innerHTML += ' ✅';
                    
                    let grid = btn.closest('.match-grid');
                    firstSelection = null;
                    checkAllMatched(grid);
                } else {
                    btn.classList.add('error');
                    firstSelection.classList.add('error');
                    setTimeout(() => {
                        btn.classList.remove('error');
                        firstSelection.classList.remove('error', 'selected');
                        firstSelection = null;
                    }, 400);
                }
            }
        }
        
        function checkAllMatched(grid) {
            const allBtns = grid.querySelectorAll('.match-btn');
            const matchedBtns = grid.querySelectorAll('.match-btn.matched');
            if(allBtns.length === matchedBtns.length) {
                let msg = grid.querySelector('.completion-msg');
                if(!msg) {
                    msg = document.createElement('div');
                    msg.className = 'completion-msg';
                    msg.innerHTML = '🎉 All Matches Found! Excellent Work!';
                    grid.appendChild(msg);
                    msg.style.display = 'block';
                }
            }
        }

        /* --- MODULE 3: PROCESS SEQUENCER JS --- */
        function revealNextStep(containerId) {
            const container = document.getElementById(containerId);
            const hiddenSteps = Array.from(container.querySelectorAll('.seq-step')).filter(s => !s.classList.contains('visible') && window.getComputedStyle(s).opacity == 0);
            
            if(hiddenSteps.length > 0) {
                const allSteps = container.querySelectorAll('.seq-step');
                const currentIndex = Array.from(allSteps).indexOf(hiddenSteps[0]);
                if(currentIndex > 0) {
                    allSteps[currentIndex-1].classList.add('arrow-visible');
                }
                hiddenSteps[0].classList.add('visible');
                
                // Update Counter
                const btn = container.querySelector('.seq-btn');
                const counterSpan = btn.querySelector('.seq-counter');
                if(counterSpan) {
                    counterSpan.innerText = `[${currentIndex + 1}/${allSteps.length}]`;
                }
            }
            if(hiddenSteps.length <= 1) { 
                const btn = container.querySelector('.seq-btn');
                if(btn) btn.style.display = 'none';
            }
        }

        /* --- MODULE 4: SPOT ERROR MODULE --- */
        function fixError(el, expId) {
            el.classList.add('fixed');
            el.innerText = 'NEVER INTERSECT';
            document.getElementById(expId).style.display = 'block';
        }

        /* --- MODULE 5: FORMULA BUILDER MODULE --- */
        function buildFormula(val, boardId, targetString) {
            const board = document.getElementById(boardId);
            if(!board || board.classList.contains('success')) return;
            
            let currentFormula = board.getAttribute('data-formula') || "";
            currentFormula += val;
            board.setAttribute('data-formula', currentFormula);
            board.innerText = currentFormula;
            
            if(currentFormula === targetString) {
                board.classList.add('success');
            }
        }
        
        function undoFormula(boardId) {
            const board = document.getElementById(boardId);
            if(!board || board.classList.contains('success')) return;
            let currentFormula = board.getAttribute('data-formula') || "";
            if(currentFormula.length > 0) {
                // Remove the last chunk added (which might be multiple chars like '1/v' or 'I²')
                // A simpler way for a rigid builder is just tracking an array. 
                // But since we appended as a string, let's just clear for V3 to keep it bulletproof, or re-implement array logic.
                // Re-implementing array logic:
                clearFormula(boardId);
            }
        }
        
        function clearFormula(boardId) {
            const board = document.getElementById(boardId);
            if(board){
                board.setAttribute('data-formula', "");
                board.innerText = "";
                board.classList.remove('success');
            }
        }

        /* --- STANDARD ASSESSMENT JS --- */
        function checkAnswer(btn, isCorrect, isMCQ) {
            const qDiv = btn.closest('.sub-slide');
            const feedback = qDiv.querySelector('.feedback');
            const nextBtn = qDiv.querySelector('.next-sub-btn');
            const buttons = qDiv.querySelectorAll('.option-btn');

            buttons.forEach(b => b.disabled = true); 
            
            if (isCorrect) {
                btn.classList.add('correct');
                feedback.innerHTML = "<span style='color: #10B981; font-weight: bold;'>Correct! (ਸਹੀ)</span>";
            } else {
                btn.classList.add('incorrect');
                feedback.innerHTML = "<span style='color: #EF4444; font-weight: bold;'>Incorrect (ਗਲਤ).</span>";
                if(isMCQ) {
                    const correctBtn = qDiv.querySelector('[data-correct="true"]');
                    if(correctBtn) correctBtn.classList.add('correct');
                }
            }
            if(nextBtn) nextBtn.style.display = 'block';
        }

        function checkSA(btn, expectedEn, expectedPa) {
            const qDiv = btn.closest('.sub-slide');
            const input = qDiv.querySelector('.sa-input');
            const feedback = qDiv.querySelector('.feedback');
            const nextBtn = qDiv.querySelector('.next-sub-btn');
            
            const userVal = input.value.trim().toLowerCase();
            const expectedVal = expectedEn.toLowerCase();
            
            input.disabled = true;
            btn.disabled = true;
            
            let feedbackHtml = `<div style="text-align: left; background: #E8F0FE; padding: 20px; border-radius: 12px; border-left: 6px solid var(--goku-primary); box-shadow: 0 4px 6px rgba(0,0,0,0.02); margin-top: 15px;">`;
            
            if(userVal === expectedVal || userVal.includes(expectedVal)) {
                feedbackHtml += `<span style="color: #10B981; font-weight: 800; font-size: 1.3rem; display: block; margin-bottom: 8px;">Correct!</span>`;
            } else {
                feedbackHtml += `<span style="color: #64748B; font-size: 1.2rem; display: block; margin-bottom: 8px;">Expected Answer:</span>`;
            }
            
            feedbackHtml += `<strong style="color: var(--goku-primary); font-size: 1.6rem; letter-spacing: 0.5px;">${expectedEn}</strong>`;
            if (expectedPa) {
                feedbackHtml += `<br><span class="punjabi-block" style="margin-top: 8px; font-weight: 500; font-size: 1.3rem;">${expectedPa}</span>`;
            }
            feedbackHtml += `</div>`;
            
            feedback.innerHTML = feedbackHtml;
            if(nextBtn) nextBtn.style.display = 'block';
        }

        function nextSubSlide(containerId, nextIndex) {
            const container = document.getElementById(containerId);
            const subSlides = container.querySelectorAll('.sub-slide');
            subSlides.forEach(s => s.classList.remove('active'));
            const nextSlide = container.querySelector('#' + containerId + '-s' + nextIndex);
            if(nextSlide) nextSlide.classList.add('active');
        }

        // Global Keyboard & Touch Nav
        document.addEventListener('keydown', (e) => {
            if (document.activeElement.tagName === 'INPUT') return;
            if (e.key === 'ArrowRight') moveSlide(1);
            else if (e.key === 'ArrowLeft') moveSlide(-1);
        });

        let touchStartX = 0;
        let touchEndX = 0;
        document.addEventListener('touchstart', e => { touchStartX = e.changedTouches[0].screenX; });
        document.addEventListener('touchend', e => { 
            touchEndX = e.changedTouches[0].screenX; 
            if(e.target.closest('.sub-slider-container') || e.target.closest('.match-grid') || e.target.closest('.cloze-paragraph') || e.target.closest('.error-diagram') || e.target.closest('.builder-workspace')) return;
            if (touchEndX < touchStartX - 50) moveSlide(1); 
            if (touchEndX > touchStartX + 50) moveSlide(-1); 
        });

        // The Transition Reset Loop
        slider.addEventListener('transitionend', () => {
            slides.forEach((slide, index) => {
                if (index !== currentSlide) {
                    // Reset Cloze
                    slide.querySelectorAll('.cloze-blank').forEach(b => {
                        b.classList.remove('revealed');
                        b.innerText = '';
                    });
                    
                    // Reset Match
                    slide.querySelectorAll('.match-btn').forEach(b => {
                        b.classList.remove('selected', 'matched', 'error');
                        b.style.pointerEvents = 'auto';
                        b.innerHTML = b.innerHTML.replace(' ✅', '');
                    });
                    slide.querySelectorAll('.completion-msg').forEach(m => m.remove());
                    firstSelection = null;

                    // Reset Sequencer
                    slide.querySelectorAll('.sequencer-container').forEach(c => {
                        c.querySelectorAll('.seq-step').forEach((s, i) => {
                            if(i !== 0) s.classList.remove('visible'); // Keep step 1 visible
                            s.classList.remove('arrow-visible');
                        });
                        const seqBtn = c.querySelector('.seq-btn');
                        if(seqBtn) {
                            seqBtn.style.display = 'block';
                            const counter = seqBtn.querySelector('.seq-counter');
                            if(counter) counter.innerText = '[0/5]'; // General reset
                        }
                    });

                    // Reset Error Spotter
                    slide.querySelectorAll('.hotspot').forEach(h => {
                        h.classList.remove('fixed');
                        h.innerText = 'INTERSECTS';
                    });
                    slide.querySelectorAll('.error-explanation').forEach(e => e.style.display = 'none');

                    // Reset Formulas
                    clearFormula('formula-board-ch9');
                    clearFormula('formula-board-ch11');

                    // Reset Standard Quizzes
                    slide.querySelectorAll('.sub-slider-container').forEach(container => {
                        if(!container.classList.contains('sequencer-container')) {
                            const subSlides = container.querySelectorAll('.sub-slide');
                            subSlides.forEach((s, i) => {
                                if(i === 0) s.classList.add('active');
                                else s.classList.remove('active');
                            });
                            
                            const btns = container.querySelectorAll('.option-btn');
                            btns.forEach(b => {
                                b.disabled = false;
                                b.classList.remove('correct', 'incorrect');
                            });

                            const inputs = container.querySelectorAll('.sa-input');
                            inputs.forEach(input => {
                                input.value = '';
                                input.disabled = false;
                            });
                            const saBtns = container.querySelectorAll('.sa-submit-btn');
                            saBtns.forEach(btn => btn.disabled = false);

                            const feedbacks = container.querySelectorAll('.feedback');
                            feedbacks.forEach(f => f.innerHTML = '');
                            const nextBtns = container.querySelectorAll('.next-sub-btn');
                            nextBtns.forEach(nb => nb.style.display = 'none');
                        }
                    });
                }
            });
        });
        
        // Bilingual Anki Export
        function exportToAnki() {
            let csvData = "";
            const saCards = document.querySelectorAll('.short-answer');
            if(saCards.length === 0) {
                alert("No Anki flashcards found in this version.");
                return;
            }
            saCards.forEach(card => {
                const q = card.getAttribute('data-q').replace(/"/g, '""');
                let aEn = card.getAttribute('data-a').replace(/"/g, '""');
                let aPa = card.getAttribute('data-pa') || "";
                
                let fullAnswer = aEn;
                if(aPa !== "") {
                    fullAnswer += ` <br><br><span style='color:#64748B;'>${aPa}</span>`;
                }
                
                csvData += `"${q}","${fullAnswer}"\n`;
            });
            const blob = new Blob(['\uFEFF' + csvData], { type: 'text/csv;charset=utf-8;' });
            const link = document.createElement("a");
            const url = URL.createObjectURL(blob);
            link.setAttribute("href", url);
            link.setAttribute("download", "Class10_Science_Phase2_Premium_v3_Anki.csv");
            link.style.visibility = 'hidden';
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        }

        updateUI();
    </script>

# ─────────────────────────────────────────────────────────────
# PSEB Content — repository ignore rules
# ─────────────────────────────────────────────────────────────

# Extracted working files (internal tool artifacts)
Scripts/_extracted/

# ── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
.Python
build/
dist/
*.egg-info/
.eggs/
.venv/
venv/
env/
ENV/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# ── Node / JS tooling (if ever added) ───────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Logs & temp files ───────────────────────────────────────
*.log
*.tmp
*.temp
*.bak
*.swp
*.swo
*~

# ── macOS ───────────────────────────────────────────────────
.DS_Store
**/.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ── Windows ─────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── Editors / IDEs ──────────────────────────────────────────
# Keep shared .vscode/settings.json tracked; ignore personal/noise files
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.sublime-workspace
*.sublime-project

# ── Environment / secrets ───────────────────────────────────
.env
.env.local
.env.*.local

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="theme-color" content="#000000">
    
    <title>BOLO.INSTINCT - Premium Prep</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Gurmukhi:wght@400;600;800&display=swap" rel="stylesheet">

    <style>
        /* =========================================
           CORE VARIABLES & FLUID SPACING
        ========================================= */
        :root {
            --bg-void: #000000; 
            --text-bold: #ffffff; 
            --text-dim: #8e9bb0;
            --shard-active: #09090b;
            
            --aura-chem: #00e5ff; 
            --aura-bio: #2ecc71;  
            --aura-phy: #b026ff;  
            --aura-env: #ffaa00;  
            
            --radius: clamp(170px, min(33vh, 35vw), 380px); 
            --fluid-curve: cubic-bezier(0.16, 1, 0.3, 1);
            --spring-curve: cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        * { box-sizing: border-box; margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; -webkit-tap-highlight-color: transparent; }

        body { 
            background-color: var(--bg-void); color: var(--text-bold); 
            height: 100vh; overflow: hidden; 
            display: flex; justify-content: center; align-items: center; 
            user-select: none; 
            -webkit-font-smoothing: antialiased;
            overscroll-behavior: none; 
        }

        body::after { 
            content: ''; position: fixed; inset: 0; 
            background: radial-gradient(circle at center, transparent 10%, rgba(0,0,0,0.98) 100%); 
            pointer-events: none; z-index: -1; 
        }

        /* Ambient FX */
        @keyframes deltaWave { 0%, 100% { opacity: 0.02; transform: scale(1); } 50% { opacity: 0.05; transform: scale(1.05); } }
        .neural-mesh { position: fixed; inset: -5%; width: 110vw; height: 110vh; background-image: radial-gradient(rgba(255,255,255,0.8) 1px, transparent 1px); background-size: 32px 32px; z-index: -3; animation: deltaWave 8s infinite ease-in-out; pointer-events: none; will-change: transform; }
        
        @keyframes auraBreathe { 0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.6; } 50% { transform: translate(-50%, -50%) scale(1.1); opacity: 0.85; } }
        .aura-bleed { position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 120vw; height: 120vh; background: radial-gradient(circle at center, transparent 0%, var(--bg-void) 65%); z-index: -2; transition: background 1s var(--fluid-curve); animation: auraBreathe 10s ease-in-out infinite; pointer-events: none; }

        @keyframes appIgnition { 0% { opacity: 0; transform: scale(0.9) translateY(20px); filter: blur(10px); } 100% { opacity: 1; transform: scale(1) translateY(0); filter: blur(0); } }

        /* =========================================
           HEADER & NAVIGATION SYSTEMS
        ========================================= */
        .web-utility-header { 
            position: fixed; top: 0; left: 0; width: 100vw; 
            padding: max(24px, env(safe-area-inset-top)) 48px 24px; 
            display: flex; justify-content: space-between; align-items: flex-start; 
            z-index: 100; pointer-events: none; animation: appIgnition 1.2s var(--fluid-curve) forwards; 
        }
        
        .header-left { display: flex; align-items: center; gap: 32px; pointer-events: auto; }
        .header-logo { 
            font-weight: 900; font-size: clamp(1.2rem, 3vw, 1.4rem); letter-spacing: 2px; 
            text-transform: uppercase; cursor: pointer; transition: transform 0.4s var(--fluid-curve), text-shadow 0.4s; 
            background: linear-gradient(135deg, #ffffff 0%, #8e9bb0 100%); 
            -webkit-background-clip: text; -webkit-text-fill-color: transparent; 
        }
        .header-center { display: flex; align-items: center; gap: 16px; }

        .domain-router { 
            display: flex; background: rgba(18, 18, 22, 0.6); 
            border: 1px solid rgba(255,255,255,0.08); border-radius: 40px; padding: 4px; 
            backdrop-filter: blur(20px); box-shadow: 0 10px 30px rgba(0,0,0,0.5); 
            transition: opacity 0.4s ease, transform 0.4s ease;
        }
        .domain-btn { 
            padding: 8px 18px; font-size: 0.7rem; font-weight: 800; text-transform: uppercase; 
            letter-spacing: 1px; color: var(--text-dim); border-radius: 30px; cursor: pointer; 
            transition: all 0.4s var(--fluid-curve); 
        }
        .domain-btn:hover { color: #fff; }
        .domain-btn.active { 
            background: rgba(255,255,255,0.12); color: #fff; 
            box-shadow: 0 4px 15px rgba(0,0,0,0.4); pointer-events: none; 
        }

        .header-divider { width: 1px; height: 32px; background: rgba(255,255,255,0.15); margin: 0 4px; }
        .header-trust { display: flex; flex-direction: column; gap: 4px; }
        .trust-primary { font-size: 1.1rem; font-weight: 800; letter-spacing: 1.5px; text-transform: uppercase; color: #ffffff; line-height: 1.1; transition: opacity 0.3s ease;}
        .trust-secondary { font-size: 0.65rem; color: #8e9bb0; letter-spacing: 1px; text-transform: uppercase; font-weight: 700; line-height: 1; transition: opacity 0.3s ease;}

        .header-right { display: flex; align-items: center; pointer-events: auto; }
        .streak-hud { display: flex; align-items: center; gap: 8px; background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.06); padding: 8px 18px; border-radius: 30px; backdrop-filter: blur(16px) saturate(150%); cursor: pointer; transition: all 0.4s var(--fluid-curve); box-shadow: 0 4px 20px rgba(0,0,0,0.4); }
        .streak-hud:hover { background: rgba(255,255,255,0.06); transform: translateY(-2px); border-color: rgba(255,255,255,0.15); box-shadow: 0 8px 25px rgba(0,0,0,0.6); }
        .streak-icon { font-size: 1.1rem; filter: drop-shadow(0 0 8px rgba(255, 115, 0, 0.6)); }
        .streak-text { font-size: 0.75rem; font-weight: 800; letter-spacing: 1px; font-variant-numeric: tabular-nums; }

        @media (max-width: 1200px) {
            .web-utility-header { flex-direction: column; gap: 20px; }
            .header-left { flex-direction: column; align-items: flex-start; gap: 16px; }
            .header-right { position: absolute; top: max(24px, env(safe-area-inset-top)); right: 24px; }
        }
        @media (max-width: 768px) {
            .web-utility-header { padding: max(20px, env(safe-area-inset-top)) 20px 20px; }
            .header-center { flex-direction: column; align-items: flex-start; gap: 12px; }
            .header-divider { display: none; }
            .header-right { top: max(20px, env(safe-area-inset-top)); right: 20px; }
        }

        /* =========================================
           CENTRAL MASS CORE
        ========================================= */
        .arena-wrapper { perspective: 1500px; width: 100vw; height: 100vh; position: relative; display: flex; justify-content: center; align-items: center; opacity: 0; animation: appIgnition 1.2s 0.2s var(--fluid-curve) forwards; }
        .arena { position: relative; width: 100%; height: 100%; display: flex; justify-content: center; align-items: center; cursor: grab; transform-style: preserve-3d; will-change: transform; backface-visibility: hidden; touch-action: none; transition: opacity 0.5s ease;}
        .arena.fade-out { opacity: 0 !important; }
        .arena:active { cursor: grabbing; }

        .core-system { position: relative; display: flex; justify-content: center; align-items: center; z-index: 10; transform-style: preserve-3d; pointer-events: none; }
        @keyframes orbitalSpin { 100% { transform: rotate(360deg); } }
        .core-ring { position: absolute; width: clamp(140px, 35vw, 190px); height: clamp(140px, 35vw, 190px); border-radius: 50%; background: conic-gradient(from 0deg, transparent 60%, rgba(255,255,255,0.05) 80%, rgba(255,255,255,0.6) 100%); -webkit-mask: radial-gradient(transparent 68%, black 69%); mask: radial-gradient(transparent 68%, black 69%); animation: orbitalSpin 4s linear infinite; transition: all 0.8s var(--fluid-curve); opacity: 0.08; }
        .core-mass { position: relative; width: clamp(110px, 28vw, 150px); height: clamp(110px, 28vw, 150px); background: rgba(10, 10, 14, 0.85); backdrop-filter: blur(24px) saturate(150%); border-radius: 50%; border: 1px solid rgba(255,255,255,0.06); display: flex; flex-direction: column; justify-content: center; align-items: center; transition: all 0.8s var(--fluid-curve); box-shadow: 0 0 50px rgba(0,0,0,0.9), inset 0 2px 10px rgba(255,255,255,0.03), inset 0 -10px 40px rgba(0,0,0,0.8); }
        .core-val { font-size: clamp(2rem, 5vw, 2.5rem); font-weight: 800; letter-spacing: -1.5px; transition: color 0.6s var(--fluid-curve), text-shadow 0.6s, transform 0.6s var(--spring-curve); z-index: 2; text-shadow: 0 0 20px rgba(255,255,255,0.1); font-variant-numeric: tabular-nums; }
        .core-lbl { font-family: 'Noto Sans Gurmukhi', sans-serif; font-size: clamp(0.6rem, 2vw, 0.7rem); text-transform: uppercase; letter-spacing: 1px; color: var(--text-dim); margin-top: 4px; transition: color 0.6s var(--fluid-curve); z-index: 2; font-weight: 600; text-align: center; padding: 0 10px;}

        /* =========================================
           DIAL & NODE MECHANICS (FOCAL LOCKED)
        ========================================= */
        .dial { position: absolute; width: 0; height: 0; display: flex; justify-content: center; align-items: center; transform-style: preserve-3d; will-change: transform; z-index: 5; }
        .node-anchor { position: absolute; transform-style: preserve-3d; will-change: transform, opacity, filter; }
        
        .arena-locked .node-anchor { transition: opacity 0.8s var(--fluid-curve), filter 0.8s var(--fluid-curve); }
        .arena-locked .node-anchor:not(.is-active) { opacity: 0 !important; filter: blur(20px) !important; pointer-events: none; }
        .node-anchor.is-active { z-index: 100 !important; opacity: 1 !important; filter: blur(0px) !important; }

        .shard-anchor.is-targeted .shard { border-top-color: rgba(255, 255, 255, 0.25); box-shadow: 0 30px 60px rgba(0,0,0,0.95), inset 0 1px 2px rgba(255,255,255,0.12); }
        .shard-anchor.is-active .shard { background: linear-gradient(180deg, rgba(15,15,18,1) 0%, rgba(5,5,8,1) 100%); width: min(92vw, 360px); border-top-color: currentColor; box-shadow: 0 50px 100px rgba(0,0,0,0.99), 0 -10px 50px rgba(currentColor, 0.3), inset 0 2px 4px rgba(255,255,255,0.15); cursor: default; --shard-scale: 1.06 !important; }
        .shard-anchor.is-active .pa-title { color: currentColor; text-shadow: 0 0 25px rgba(currentColor, 0.6); }
        .shard-anchor.is-active .btn-prime { border-color: currentColor; color: currentColor; background: rgba(currentColor, 0.08); }
        .shard-anchor.is-active .ch-icon { color: currentColor; filter: drop-shadow(0 0 8px currentColor); }

        .shard { 
            position: absolute; width: min(88vw, 330px); background: rgba(18, 18, 22, 0.95); 
            border-radius: 24px; padding: clamp(16px, 4vw, 24px); cursor: pointer; display: flex; flex-direction: column; gap: 0; 
            box-shadow: inset 0 1px 1px rgba(255,255,255,0.05), 0 20px 40px rgba(0,0,0,0.95); border: 1px solid rgba(255,255,255,0.04); 
            --shard-rot: 0deg; --shard-scale: 1; transform: translate(-50%, -50%) rotate(var(--shard-rot)) scale(var(--shard-scale)); 
            will-change: transform; overflow: hidden; backface-visibility: hidden; 
            transition: background 0.6s var(--fluid-curve), box-shadow 0.6s var(--fluid-curve), border-color 0.6s var(--fluid-curve), width 0.6s var(--fluid-curve), transform 0.6s var(--fluid-curve); 
        }

        .s-head { display: flex; justify-content: space-between; align-items: flex-start; z-index: 2; position: relative; }
        .s-titles { display: flex; gap: 14px; align-items: flex-start; overflow: hidden; }
        .ch-icon { width: 14px; height: 14px; color: var(--text-dim); margin-top: 6px; flex-shrink: 0; transition: color 0.5s var(--fluid-curve); }
        .ch-icon svg { width: 100%; height: 100%; stroke: currentColor; }
        .ch-num { font-size: 0.85rem; font-weight: 900; color: var(--text-dim); flex-shrink: 0; padding-top: 4px; font-variant-numeric: tabular-nums; }
        .title-group { display: flex; flex-direction: column; gap: 2px; min-width: 0; padding-right: 8px;}
        .pa-title { font-family: 'Noto Sans Gurmukhi', sans-serif; font-size: clamp(1rem, 3.5vw, 1.1rem); font-weight: 700; color: var(--text-bold); white-space: normal; line-height: 1.35; transition: color 0.5s var(--fluid-curve), text-shadow 0.5s var(--fluid-curve); }
        .en-title { font-size: 0.7rem; font-weight: 700; color: var(--text-dim); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; letter-spacing: 0.5px; text-transform: uppercase;}

        .svg-progress-container { position: relative; width: clamp(38px, 10vw, 44px); height: clamp(38px, 10vw, 44px); display: flex; justify-content: center; align-items: center; flex-shrink: 0; cursor: pointer; border-radius: 50%; transition: transform 0.4s var(--spring-curve), background 0.4s ease; z-index: 10; }
        .prog-ring { width: 100%; height: 100%; transform: rotate(-90deg); position: absolute; top: 0; left: 0; pointer-events: none; }
        .prog-ring circle { fill: transparent; stroke-width: 2.5; }
        .prog-ring .bg { stroke: rgba(255,255,255,0.05); }
        .prog-ring .fill { stroke: currentColor; stroke-dasharray: 100; stroke-linecap: round; transition: stroke-dashoffset 0.8s var(--spring-curve); }
        .prog-text { font-size: 0.65rem; font-weight: 800; color: var(--text-dim); z-index: 1; pointer-events: none; transition: color 0.5s var(--fluid-curve); font-variant-numeric: tabular-nums; }
        .shard-anchor.is-active .prog-text { color: currentColor; }
        .svg-progress-container.done .prog-text { color: currentColor; text-shadow: 0 0 10px rgba(currentColor, 0.6); font-size: 0.8rem; }
        .svg-progress-container.done .fill { stroke-dashoffset: 0 !important; filter: drop-shadow(0 0 6px rgba(currentColor, 0.4)); }

        .s-expansion { display: grid; grid-template-rows: 0fr; transition: grid-template-rows 0.6s var(--fluid-curve); width: 100%; }
        .s-expansion-inner { min-height: 0; overflow: hidden; display: flex; flex-direction: column; gap: 16px; padding-top: 0; transition: padding-top 0.6s var(--fluid-curve), opacity 0.4s ease; opacity: 0; }
        .shard-anchor.is-active .s-expansion { grid-template-rows: 1fr; }
        .shard-anchor.is-active .s-expansion-inner { padding-top: 16px; opacity: 1; }
        .rune-row { display: flex; gap: 8px; flex-wrap: wrap; }
        .rune { font-family: 'Noto Sans Gurmukhi', sans-serif; font-size: 0.6rem; font-weight: 600; padding: 6px 12px; border-radius: 8px; background: rgba(255,255,255,0.04); color: var(--text-dim); letter-spacing: 0.5px; border: 1px solid rgba(255,255,255,0.02);}
        .btn-prime { position: relative; overflow: hidden; background: rgba(255,255,255,0.02); color: var(--text-bold); border: 1px solid rgba(255,255,255,0.08); padding: 14px 18px; border-radius: 12px; font-family: 'Noto Sans Gurmukhi', sans-serif; font-size: 0.85rem; font-weight: 600; letter-spacing: 0.5px; cursor: pointer; transition: all 0.4s var(--fluid-curve); display: flex; justify-content: space-between; align-items: center; }

        /* BOTTOM MIRRORS */
        .mirror-anchor.is-targeted .lecture-mirror { border-color: rgba(255,255,255,0.25); border-bottom-color: currentColor; box-shadow: 0 20px 50px rgba(0,0,0,0.9), inset 0 1px 2px rgba(255,255,255,0.2); }
        .mirror-anchor.is-targeted .mirror-title { text-shadow: 0 0 15px currentColor; color: var(--text-bold); }
        .mirror-anchor.is-targeted .mirror-icon { color: currentColor; background: rgba(255,255,255,0.12); }
        
        .mirror-anchor.is-active .lecture-mirror { background: linear-gradient(145deg, rgba(20, 20, 25, 1), rgba(10, 10, 14, 1)); border-color: currentColor; box-shadow: 0 20px 60px rgba(0,0,0,0.9), 0 0 35px rgba(currentColor, 0.45), inset 0 1px 4px rgba(currentColor, 0.5); --node-scale: 1.15 !important; }
        .mirror-anchor.is-active .mirror-title { color: currentColor; text-shadow: 0 0 25px rgba(currentColor, 0.8); }
        .mirror-anchor.is-active .mirror-icon { color: #000; background: currentColor; box-shadow: 0 0 20px currentColor; }

        .lecture-mirror { 
            position: absolute; width: max-content; max-width: 90vw; background: rgba(22, 20, 26, 0.95); 
            border: 1px solid rgba(255, 255, 255, 0.08); padding: 8px 24px 8px 8px; border-radius: 50px; display: flex; align-items: center; gap: clamp(10px, 3vw, 16px); 
            box-shadow: 0 20px 50px rgba(0,0,0,0.8), inset 0 1px 2px rgba(255,255,255,0.1); 
            --node-rot: 0deg; --node-scale: 1; transform: translate(-50%, -50%) rotate(var(--node-rot)) scale(var(--node-scale));
            will-change: transform; backface-visibility: hidden; cursor: pointer;
            transition: transform 0.6s var(--fluid-curve), border-color 0.6s var(--fluid-curve), background 0.6s var(--fluid-curve), box-shadow 0.6s var(--fluid-curve);
        }
        @media (max-width: 768px) { .lecture-mirror { padding: 6px 20px 6px 6px; border-radius: 40px; } }
        .mirror-icon { display: flex; justify-content: center; align-items: center; width: clamp(32px, 8vw, 36px); height: clamp(32px, 8vw, 36px); border-radius: 50%; background: rgba(255,255,255,0.05); color: var(--text-dim); transition: all 0.6s var(--fluid-curve); flex-shrink: 0;}
        .mirror-icon svg { width: 14px; height: 14px; fill: currentColor; margin-left: 2px; }
        .mirror-text-container { display: flex; flex-direction: column; gap: 2px; justify-content: center; min-width: 0;}
        .mirror-label { font-family: 'Noto Sans Gurmukhi', sans-serif; font-size: 0.55rem; font-weight: 800; text-transform: uppercase; letter-spacing: 1.5px; color: var(--text-dim); opacity: 0.8; }
        .mirror-title { font-family: 'Noto Sans Gurmukhi', sans-serif; font-size: clamp(0.85rem, 3vw, 0.95rem); font-weight: 600; color: var(--text-bold); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; transition: color 0.6s var(--fluid-curve), text-shadow 0.6s var(--fluid-curve); line-height: 1.1; }

        /* =========================================
           MODAL MODES (ORGANIC SHARE OVERLAY)
        ========================================= */
        .cmd-palette { position: fixed; inset: 0; background: rgba(0,0,0,0.85); backdrop-filter: blur(30px); display: flex; justify-content: center; align-items: flex-start; padding-top: 15vh; z-index: 999; opacity: 0; pointer-events: none; transition: opacity 0.5s var(--fluid-curve); }
        .cmd-palette.is-open { opacity: 1; pointer-events: auto; }
        .cmd-box { width: 90%; max-width: 500px; background: #0c0c0e; border: 1px solid rgba(255,255,255,0.08); border-radius: 24px; overflow: hidden; box-shadow: 0 40px 100px rgba(0,0,0,0.9); transform: translateY(-30px) scale(0.95); transition: all 0.5s var(--fluid-curve); padding: 24px; }
        .cmd-palette.is-open .cmd-box { transform: translateY(0) scale(1); }
        
        .modal-title { font-size: 0.9rem; font-weight: 800; letter-spacing: 1.5px; text-transform: uppercase; color: var(--text-bold); margin-bottom: 20px; text-align: center; border-bottom: 1px solid rgba(255,255,255,0.06); padding-bottom: 12px; }
        .share-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
        .share-tile { background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.06); padding: 18px; border-radius: 16px; color: #ffffff; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8px; cursor: pointer; transition: all 0.3s var(--fluid-curve); font-size: 0.75rem; font-weight: 700; letter-spacing: 0.5px; text-transform: uppercase;}
        .share-tile:hover { background: rgba(255,255,255,0.06); border-color: rgba(255,255,255,0.15); transform: translateY(-2px); }
        .share-tile svg { width: 22px; height: 22px; fill: currentColor; }
        
        /* Floating Trigger */
        .share-hub-container { position: fixed; bottom: max(24px, env(safe-area-inset-bottom)); right: 48px; z-index: 100; pointer-events: auto; }
        .share-trigger { width: 48px; height: 48px; border-radius: 50%; background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.08); color: var(--text-bold); display: flex; align-items: center; justify-content: center; cursor: pointer; backdrop-filter: blur(16px); box-shadow: 0 10px 30px rgba(0,0,0,0.5); transition: transform 0.3s var(--fluid-curve); }
        .share-trigger:hover { transform: scale(1.05); background: rgba(255,255,255,0.06); }
        .share-trigger svg { width: 16px; height: 16px; fill: currentColor; }
        @media (max-width: 768px) { .share-hub-container { bottom: max(20px, env(safe-area-inset-bottom)); right: 20px; } }

        .toast-notify { position: fixed; bottom: max(90px, env(safe-area-inset-bottom)); right: 48px; background: #09090b; border: 1px solid rgba(255,255,255,0.15); padding: 12px 24px; border-radius: 12px; font-family: 'Noto Sans Gurmukhi', sans-serif; font-size: 0.75rem; font-weight: 700; letter-spacing: 0.5px; color: var(--text-bold); opacity: 0; transform: translateY(10px); transition: all 0.4s var(--fluid-curve); pointer-events: none; z-index: 1000; box-shadow: 0 10px 30px rgba(0,0,0,0.8); }
        .toast-notify.show { opacity: 1; transform: translateY(0); }
        @media (max-width: 768px) { .toast-notify { right: 20px; bottom: max(80px, env(safe-area-inset-bottom)); } }

        .particle { position: absolute; width: 4px; height: 4px; background: #fff; border-radius: 50%; pointer-events: none; opacity: 0; z-index: 99; }
        .gateway-core { position: fixed; top: 50%; left: 50%; width: 5px; height: 5px; border-radius: 50%; background: #fff; opacity: 0; pointer-events: none; transform: translate(-50%, -50%) scale(1); transition: transform 0.8s cubic-bezier(0.8, 0, 0.2, 1), opacity 0.6s, box-shadow 0.8s; z-index: 9999; }
        body.gateway-active .gateway-core { opacity: 1; transform: translate(-50%, -50%) scale(600); box-shadow: 0 0 150px 80px #fff; }
        .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0, 0, 0, 0); border: 0; }
    </style>
</head>
<body>

    <div id="ariaAnnouncer" class="sr-only" aria-live="polite" aria-atomic="true"></div>

    <header class="web-utility-header">
        <div class="header-left">
            <div class="header-logo" onclick="location.reload()">BOLO.INSTINCT</div>
            
            <div class="header-center">
                <div class="domain-router">
                    <div class="domain-btn active" data-domain="PSEB">PSEB</div>
                    <div class="domain-btn" data-domain="IM">IM</div>
                </div>
                
                <div class="domain-router" id="subjectRouter">
                    <div class="domain-btn active" data-subject="SCI">SCIENCE</div>
                    <div class="domain-btn" data-subject="MATH">MATH</div>
                </div>
                
                <div class="header-divider"></div>
                
                <div class="header-trust">

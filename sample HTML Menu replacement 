    <script>
        const syllabus = [
            { id: 1, en: "Chemical Reactions", pa: "ਰਸਾਇਣਕ ਪ੍ਰਤੀਕ੍ਰਿਆਵਾਂ", type: "chem", defaultVal: 100, slides: 27 },
            { id: 2, en: "Acids, Bases and Salts", pa: "ਤੇਜ਼ਾਬ, ਖਾਰ ਅਤੇ ਲੂਣ", type: "chem", defaultVal: 25, slides: 29 },
            { id: 3, en: "Metals and Non-metals", pa: "ਧਾਤਾਂ ਅਤੇ ਅਧਾਤਾਂ", type: "chem", defaultVal: 4, slides: 27 },
            { id: 4, en: "Carbon and its Compounds", pa: "ਕਾਰਬਨ ਅਤੇ ਇਸਦੇ ਯੋਗਿਕ", type: "chem", defaultVal: 0, slides: 29 },
            { id: 5, en: "Periodic Classification", pa: "ਤੱਤਾਂ ਦਾ ਆਵਰਤੀ ਵਰਗੀਕਰਣ", type: "chem", defaultVal: 0, slides: 27 },
            { id: 6, en: "Life Processes", pa: "ਜੀਵਨ ਪ੍ਰਕਿਰਿਆਵਾਂ", type: "bio", defaultVal: 0, slides: 42 }, 
            { id: 7, en: "Control and Coordination", pa: "ਨਿਯੰਤਰਣ ਅਤੇ ਤਾਲਮੇਲ", type: "bio", defaultVal: 0, slides: 31 },
            { id: 8, en: "How do Organisms Reproduce?", pa: "ਜੀਵ ਕਿਵੇਂ ਪ੍ਰਜਨਨ ਕਰਦੇ ਹਨ", type: "bio", defaultVal: 100, slides: 33 },
            { id: 9, en: "Heredity and Evolution", pa: "ਅਨੁਵੰਸ਼ਿਕਤਾ ਅਤੇ ਵਿਕਾਸ", type: "bio", defaultVal: 100, slides: 27 },
            { id: 10, en: "Light: Reflection & Refraction", pa: "ਪ੍ਰਕਾਸ਼: ਪਰਾਵਰਤਨ", type: "phy", defaultVal: 0, slides: 33 },
            { id: 11, en: "The Human Eye", pa: "ਮਨੁੱਖੀ ਅੱਖ", type: "phy", defaultVal: 100, slides: 32 },
            { id: 12, en: "Electricity", pa: "ਬਿਜਲੀ", type: "phy", defaultVal: 0, slides: 31 },
            { id: 13, en: "Magnetic Effects", pa: "ਚੁੰਬਕੀ ਪ੍ਰਭਾਵ", type: "phy", defaultVal: 100, slides: 33 },
            { id: 14, en: "Sources of Energy", pa: "ਊਰਜਾ ਦੇ ਸੋਮੇ", type: "phy", defaultVal: 0, slides: 24 }, 
            { id: 15, en: "Our Environment", pa: "ਸਾਡਾ ਵਾਤਾਵਰਣ", type: "env", defaultVal: 0, slides: 27 },
            { id: 16, en: "Sustainable Management", pa: "ਕੁਦਰਤੀ ਸਾਧਨਾਂ ਦਾ ਪ੍ਰਬੰਧ", type: "env", defaultVal: 0, slides: 18 } 
        ];

        const auras = { 'chem': '#00e5ff', 'bio': '#2ecc71', 'phy': '#b026ff', 'env': '#ffaa00' };
        
        const icons = {
            'chem': `<svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 2v7.31"/><path d="M14 9.3V1.99"/><path d="M8.5 2h7"/><path d="M14 9.3a6.5 6.5 0 1 1-4 0"/><circle cx="12" cy="16" r="1"/></svg>`,
            'bio': `<svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c-4-4-4-10 0-14 4 4 4 10 0 14z"/><path d="M12 22V8"/></svg>`,
            'phy': `<svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1 0-2.83 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>`,
            'env': `<svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>`
        };
        
        let localData = {};
        try {
            const rawCache = localStorage.getItem('bolo_pseb_data');
            if(rawCache) localData = JSON.parse(rawCache) || {};
        } catch(e) { localData = {}; }
        
        let isLocked = false; let currentAngle = 0; let targetAngle = 0; let isDragging = false; 
        let startX = 0; let velocity = 0; let lastX = 0; let lastTickIdx = -1; 
        let isLooping = false; 
        let currentDomain = 'PSEB';
        let currentSubject = 'SCI';
        let isPlaceholderView = false;
        const degreePerNode = 360 / syllabus.length;

        const dial = document.getElementById('dial');
        const arena = document.getElementById('arena');
        const coreVal = document.getElementById('coreVal');
        const coreLbl = document.getElementById('coreLbl');
        const coreMass = document.getElementById('coreMass');
        const coreRing = document.getElementById('coreRing');
        const gatewayCore = document.getElementById('gatewayCore');
        const neuralMesh = document.getElementById('neuralMesh');
        const ariaAnnouncer = document.getElementById('ariaAnnouncer');
        const sharePalette = document.getElementById('sharePalette');

        let audioCtx;
        function initAudio() { 
            if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
            if (audioCtx.state === 'suspended') audioCtx.resume();
        }
        function playTick(vol = 0.15, freq = 150) {
            if (!audioCtx) return;
            const osc = audioCtx.createOscillator(); const gainNode = audioCtx.createGain();
            osc.type = 'sine'; osc.frequency.setValueAtTime(freq, audioCtx.currentTime);
            osc.frequency.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.1);
            gainNode.gain.setValueAtTime(vol, audioCtx.currentTime);
            gainNode.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.1);
            osc.connect(gainNode); gainNode.connect(audioCtx.destination);
            osc.start(); osc.stop(audioCtx.currentTime + 0.1);
        }

        function showToast(msg) {
            const toast = document.getElementById('toastNotify');
            toast.innerText = msg; toast.classList.add('show');
            setTimeout(() => { toast.classList.remove('show'); }, 2500);
        }

        /* =========================================
           PRODUCTION ROUTING & SHARING SYSTEM (ORGANIC)
        ========================================= */
        function toggleShareModal(open) {
            if(open) { sharePalette.classList.add('is-open'); } 
            else { sharePalette.classList.remove('is-open'); }
        }

        function executeExplicitShare(platform) {
            initAudio(); playTick(0.25, 450);
            const appUrl = window.location.href;
            
            // Organic, utility-focused text meant for student-to-student sharing
            const shareText = "Accelerate your PSEB Class 10 Board preparation with the free BOLO.INSTINCT platform.";
            
            if (platform === 'whatsapp') {
                const waUrl = `https://api.whatsapp.com/send?text=${encodeURIComponent(shareText + "\n\n🔗 Link: " + appUrl)}`;
                window.open(waUrl, '_blank');
            } 
            else if (platform === 'telegram') {
                const tgUrl = `https://t.me/share/url?url=${encodeURIComponent(appUrl)}&text=${encodeURIComponent(shareText)}`;
                window.open(tgUrl, '_blank');
            }
            else if (platform === 'email') {
                const mailUrl = `mailto:?subject=${encodeURIComponent("BOLO.INSTINCT Board Preparation Platform")}&body=${encodeURIComponent(shareText + "\n\nExplore here: " + appUrl)}`;
                window.open(mailUrl, '_self');
            } 
            else if (platform === 'system') {
                if (navigator.share) {
                    navigator.share({ title: 'BOLO.INSTINCT', text: shareText, url: appUrl }).catch(e => console.log(e));
                } else {
                    navigator.clipboard.writeText(appUrl).then(() => {
                        showToast("ਸਿਲੇਬਸ lਲਿੰਕ ਕਾਪੀ ਹੋ ਗਿਆ ਹੈ! (Link Copied)");
                    });
                }
            }
            toggleShareModal(false);
        }

        function setView(domain, subject) {
            currentDomain = domain;
            if (subject) currentSubject = subject;

            document.querySelectorAll('[data-domain]').forEach(b => b.classList.toggle('active', b.getAttribute('data-domain') === currentDomain));
            document.querySelectorAll('[data-subject]').forEach(b => b.classList.toggle('active', b.getAttribute('data-subject') === currentSubject));

            const subjRouter = document.getElementById('subjectRouter');
            if (currentDomain === 'IM') { subjRouter.style.display = 'none'; } 
            else { subjRouter.style.display = 'flex'; }

            let newTitle = ""; let toastMsg = ""; isPlaceholderView = false;

            if (currentDomain === 'IM') {
                newTitle = "INTERNAL MEDICINE"; toastMsg = "Internal Medicine modules coming soon!"; isPlaceholderView = true;
            } else if (currentDomain === 'PSEB') {
                if (currentSubject === 'MATH') {
                    newTitle = "PSEB 10TH MATH"; toastMsg = "PSEB Math modules coming soon!"; isPlaceholderView = true;
                } else { newTitle = "PSEB 10TH SCIENCE"; }
            }

            const tPrimary = document.getElementById('trustPrimary');
            tPrimary.style.opacity = 0;
            setTimeout(() => { tPrimary.innerText = newTitle; tPrimary.style.opacity = 1; }, 300);

            arena.classList.add('fade-out');
            setTimeout(() => {
                isLocked = false;
                if (isPlaceholderView) {
                    dial.innerHTML = ''; coreRing.style.opacity = '0.02';
                    coreVal.innerText = '🔒'; coreVal.style.color = 'var(--text-dim)'; coreVal.style.textShadow = 'none'; coreVal.style.transform = 'scale(1)';
                    coreLbl.innerText = 'COMING SOON'; coreLbl.style.color = 'var(--text-dim)';
                    coreMass.style.borderColor = 'rgba(255,255,255,0.02)';
                    coreMass.style.boxShadow = 'inset 0 2px 10px rgba(255,255,255,0.01), inset 0 -10px 40px rgba(0,0,0,0.8)';
                    showToast(toastMsg);
                } else { initDial(); }
                arena.classList.remove('fade-out');
            }, 400);
        }

        function getActiveIndex() {
            let normalized = ((targetAngle % 360) + 360) % 360;
            return (syllabus.length - Math.round(normalized / degreePerNode)) % syllabus.length;
        }

        function updateGlobalSync() {
            if (isPlaceholderView) return;
            let total = 0;
            syllabus.forEach(c => total += (localData[c.id] !== undefined ? localData[c.id] : c.defaultVal));
            if(!isLocked) coreVal.innerText = Math.floor(total / syllabus.length) + '%';
        }

        function createBurst(x, y, color) {
            for (let i = 0; i < 12; i++) {
                const particle = document.createElement('div');
                particle.className = 'particle'; particle.style.background = color;
                particle.style.left = x + 'px'; particle.style.top = y + 'px';
                document.body.appendChild(particle);

                const angle = Math.random() * Math.PI * 2;
                const velocity = 20 + Math.random() * 40;
                const tx = Math.cos(angle) * velocity; const ty = Math.sin(angle) * velocity;

                particle.animate([ { transform: 'translate(0, 0) scale(1.5)', opacity: 1 }, { transform: `translate(${tx}px, ${ty}px) scale(0)`, opacity: 0 } ], { duration: 600 + Math.random() * 400, easing: 'cubic-bezier(0.16, 1, 0.3, 1)' });
                setTimeout(() => particle.remove(), 1000);
            }
        }

        function initDial() {
            dial.innerHTML = '';
            let savedIdx = parseInt(localStorage.getItem('bolo_pseb_idx')) || 0;
            if (savedIdx >= syllabus.length) savedIdx = 0;

            syllabus.forEach((chap, index) => {
                const angle = index * degreePerNode; 
                const color = auras[chap.type] || '#ffffff';
                const currentVal = localData[chap.id] !== undefined ? localData[chap.id] : chap.defaultVal;
                const isDone = currentVal === 100;
                
                let actionText = "ਲੈਕਚਰ ਸ਼ੁਰੂ ਕਰੋ"; 
                if(isDone) actionText = "ਦੁਹਰਾਈ ਕਰੋ"; else if(currentVal > 0) actionText = `ਮੁੜ-ਸ਼ੁਰੂ ਕਰੋ ${currentVal}%`;

                const anchor = document.createElement('article');
                anchor.className = `node-anchor shard-anchor`; anchor.id = `shard-anchor-${index}`;
                anchor.style.transform = `rotate(${angle}deg) translateY(calc(var(--radius) * -1))`;
                anchor.style.color = color;

                const shard = document.createElement('div'); shard.className = `shard`; 
                
                let progressSVG = `
                    <div class="svg-progress-container ${isDone ? 'done' : ''}" data-node-progress="${chap.id}" title="Cycle Progress" tabindex="0" role="button">
                        <svg class="prog-ring" viewBox="0 0 36 36"><circle class="bg" cx="18" cy="18" r="16"></circle><circle class="fill" id="fill-${chap.id}" cx="18" cy="18" r="16" stroke-dashoffset="${100 - currentVal}"></circle></svg>
                        <span class="prog-text" id="text-${chap.id}">${isDone ? '✓' : currentVal + '%'}</span>
                    </div>`;

                let lockButton = `<button class="btn-prime" data-gateway-trigger="${color}"><span id="action-${chap.id}">${actionText}</span><span>▶</span></button>`;

                shard.innerHTML = `
                    <div class="s-head">
                        <div class="s-titles" data-node-select="${index}">
                            <div class="ch-icon">${icons[chap.type]}</div>
                            <div class="ch-num">${chap.id.toString().padStart(2, '0')}</div>
                            <div class="title-group">
                                <span class="pa-title">${chap.pa}</span>
                                <span class="en-title">${chap.en}</span>
                            </div>
                        </div>
                        ${progressSVG}
                    </div>
                    <div class="s-expansion">
                        <div class="s-expansion-inner">
                            <div class="rune-row"><span class="rune">${chap.slides} ਭਾਗ (Nodes)</span></div>
                            ${lockButton}
                        </div>
                    </div>
                `;
                anchor.appendChild(shard);

                const mirrorAnchor = document.createElement('article');
                mirrorAnchor.className = `node-anchor mirror-anchor`; mirrorAnchor.id = `mirror-anchor-${index}`;
                mirrorAnchor.style.transform = `rotate(${angle}deg) translateY(calc(var(--radius) * 1.05))`;
                mirrorAnchor.style.color = color;

                const mirror = document.createElement('div'); mirror.className = 'lecture-mirror';
                mirror.setAttribute('data-node-select', index);
                mirror.innerHTML = `
                    <div class="mirror-icon"><svg viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg></div>
                    <div class="mirror-text-container">
                        <span class="mirror-label">ਵੀਡੀਓ ਲੈਕਚਰ (Video)</span>
                        <span class="mirror-title">${chap.pa}</span>
                    </div>
                `;
                mirrorAnchor.appendChild(mirror);

                dial.appendChild(anchor); dial.appendChild(mirrorAnchor);
            });

            targetAngle = -savedIdx * degreePerNode; velocity = 0; resetCore(); wakePhysicsLoop();
        }

        function markComplete(e, id) {
            e.stopPropagation(); initAudio();
            const chap = syllabus.find(s => s.id === parseInt(id)); if(!chap) return;

            let currentVal = localData[id] !== undefined ? localData[id] : chap.defaultVal;
            currentVal = currentVal >= 100 ? 0 : currentVal + 25;
            localData[id] = currentVal; localStorage.setItem('bolo_pseb_data', JSON.stringify(localData));
            
            const container = document.getElementById(`prog-${id}`);
            const fill = document.getElementById(`fill-${id}`);
            const text = document.getElementById(`text-${id}`);
            const actionBtn = document.getElementById(`action-${id}`);
            
            fill.style.strokeDashoffset = 100 - currentVal;
            
            if(currentVal === 100) {
                playTick(0.4, 900); createBurst(e.clientX, e.clientY, auras[chap.type] || '#ffffff'); 
                container.classList.add('done'); text.innerText = '✓'; actionBtn.innerText = 'ਦੁਹਰਾਈ ਕਰੋ';
            } else {
                playTick(0.2, 500);
                container.classList.remove('done'); text.innerText = currentVal + '%';
                actionBtn.innerText = currentVal > 0 ? `ਮੁੜ-ਸ਼ੁਰੂ ਕਰੋ ${currentVal}%` : 'ਲੈਕਚਰ ਸ਼ੁਰੂ ਕਰੋ';
            }
            
            if(isLocked && syllabus[getActiveIndex()].id === parseInt(id)) { coreVal.innerText = currentVal + "%"; } 
            updateGlobalSync(); wakePhysicsLoop();
        }

        function wakePhysicsLoop() {
            if (!isLooping && !isPlaceholderView) { isLooping = true; requestAnimationFrame(renderPhysics); }
        }

        function renderPhysics() {
            if (isPlaceholderView || dial.innerHTML === '') { isLooping = false; return; }
            let needsMoreFrames = false;

            if (!isDragging) {
                targetAngle += velocity; velocity *= 0.92; 
                if (Math.abs(velocity) < 0.005) { velocity = 0; } else { needsMoreFrames = true; }

                let closestSnap = Math.round(targetAngle / degreePerNode) * degreePerNode;
                let snapDiff = closestSnap - targetAngle;
                if (Math.abs(snapDiff) > 0.005) { targetAngle += snapDiff * 0.15; needsMoreFrames = true; } 
                else if (velocity === 0) { targetAngle = closestSnap; }
            } else { needsMoreFrames = true; }

            let angleDiff = targetAngle - currentAngle;
            if (Math.abs(angleDiff) > 0.005) { currentAngle += angleDiff * 0.2; needsMoreFrames = true; } 
            else { currentAngle = targetAngle; }

            dial.style.transform = `rotate(${currentAngle}deg)`;
            let tilt = Math.max(-10, Math.min(10, velocity * 1.2));
            arena.style.transform = `rotateY(${-tilt}deg) rotateX(${Math.abs(tilt)/4}deg)`;

            let activeIdx = getActiveIndex();

            for (let i = 0; i < syllabus.length; i++) {
                const nodeAngle = i * degreePerNode; const counterRot = `${-(nodeAngle + currentAngle)}deg`;
                let distRaw = Math.abs(((nodeAngle + currentAngle) % 360 + 360) % 360);
                if (distRaw > 180) distRaw = 360 - distRaw; 
                
                let adjustedDist = Math.max(0, distRaw - 15);
                let depthRatio = Math.min(adjustedDist / 75, 1); let easeDepth = Math.pow(depthRatio, 1.4);

                const sAnchor = document.getElementById(`shard-anchor-${i}`);
                const mAnchor = document.getElementById(`mirror-anchor-${i}`);
                if(!sAnchor || !mAnchor) continue;

                sAnchor.querySelector('.shard').style.setProperty('--shard-rot', counterRot);
                mAnchor.querySelector('.lecture-mirror').style.setProperty('--node-rot', counterRot);

                if(!isLocked) {
                    let sScale = 1 - (easeDepth * 0.4); let sOpacity = 1 - (easeDepth * 0.9); let sBlur = easeDepth * 12; let sZIndex = Math.round((1 - easeDepth) * 100); 
                    sAnchor.style.opacity = sOpacity; sAnchor.style.filter = `blur(${sBlur}px)`; sAnchor.style.zIndex = sZIndex;
                    sAnchor.querySelector('.shard').style.setProperty('--shard-scale', sScale);
                    mAnchor.style.opacity = sOpacity; mAnchor.style.filter = `blur(${sBlur}px)`; mAnchor.style.zIndex = sZIndex;
                    mAnchor.querySelector('.lecture-mirror').style.setProperty('--node-scale', sScale);

                    let dist = Math.min(Math.abs(i - activeIdx), syllabus.length - Math.abs(i - activeIdx));
                    [sAnchor, mAnchor].forEach(node => {
                        node.classList.remove('is-targeted', 'is-faded-1', 'is-faded-2', 'is-culled');
                        if (dist === 0) { node.classList.add('is-targeted'); }
                        else if (dist === 1) { node.classList.add('is-faded-1'); }
                        else if (dist === 2) { node.classList.add('is-faded-2'); }
                        else { node.classList.add('is-culled'); }
                    });
                }
            }

            if(activeIdx !== lastTickIdx && !isLocked) {
                if(Math.abs(targetAngle - currentAngle) > 1.5 && lastTickIdx !== -1) { 
                    playTick(0.08 + (Math.abs(velocity)/120)); if(navigator.vibrate) navigator.vibrate(4);
                }
                lastTickIdx = activeIdx; localStorage.setItem('bolo_pseb_idx', activeIdx);
            }

            if (needsMoreFrames || isDragging || isLocked) { requestAnimationFrame(renderPhysics); } 
            else { isLooping = false; }
        }

        /* =========================================
           EVENT DELEGATION SUITE
        ========================================= */
        document.body.addEventListener('click', (e) => {
            initAudio(); 
            
            const actionBtn = e.target.closest('[data-action]');
            if (actionBtn) {
                const action = actionBtn.getAttribute('data-action');
                if (action === 'open-share') { toggleShareModal(true); return; }
                return;
            }

            const domainSwitch = e.target.closest('[data-domain]');
            if (domainSwitch) { setView(domainSwitch.getAttribute('data-domain'), currentSubject); return; }

            const subjectSwitch = e.target.closest('[data-subject]');
            if (subjectSwitch) { setView(currentDomain, subjectSwitch.getAttribute('data-subject')); return; }

            const shareTile = e.target.closest('[data-share]');
            if (shareTile) { executeExplicitShare(shareTile.getAttribute('data-share')); return; }

            if (e.target === sharePalette) { toggleShareModal(false); return; }

            const progressTarget = e.target.closest('[data-node-progress]');
            if (progressTarget) { markComplete(e, progressTarget.getAttribute('data-node-progress')); return; }

            const gatewayTrigger = e.target.closest('[data-gateway-trigger]');
            if (gatewayTrigger) { triggerGateway(e, gatewayTrigger.getAttribute('data-gateway-trigger')); return; }

            const nodeSelect = e.target.closest('[data-node-select]');
            if (nodeSelect) { handleNodeAction(parseInt(nodeSelect.getAttribute('data-node-select'))); return; }

            if (isLocked && e.target === arena && !isPlaceholderView) { resetCore(); }
        });

        // Kinetic Drag Interface
        function handleDragStart(x) { if(isLocked || isPlaceholderView) return; initAudio(); isDragging = true; startX = x; lastX = x; velocity = 0; wakePhysicsLoop(); }
        function handleDragMove(e) {
            if (!isDragging || isLocked || isPlaceholderView) return;
            let currentClientX = e.touches ? e.touches[0].clientX : e.clientX;
            let delta = currentClientX - lastX; let sensitivity = window.innerWidth < 768 ? 1.4 : 0.8;
            targetAngle += delta * 0.4 * sensitivity; velocity = delta * 0.7 * sensitivity; lastX = currentClientX;
            wakePhysicsLoop();
        }
        function handleDragEnd() { isDragging = false; wakePhysicsLoop(); }

        arena.addEventListener('mousedown', e => handleDragStart(e.clientX));
        window.addEventListener('mousemove', e => { if(isDragging) { e.preventDefault(); handleDragMove(e); } });
        window.addEventListener('mouseup', handleDragEnd);
        arena.addEventListener('touchstart', e => { handleDragStart(e.touches[0].clientX); }, {passive: false});
        arena.addEventListener('touchmove', e => { if(isDragging) { e.preventDefault(); handleDragMove(e); } }, {passive: false});
        window.addEventListener('touchend', handleDragEnd);

        window.addEventListener('mousemove', (e) => {
            const x = (e.clientX / window.innerWidth - 0.5) * 20; const y = (e.clientY / window.innerHeight - 0.5) * 20;
            neuralMesh.style.transform = `translate(${x}px, ${y}px)`;
        });

        function handleNodeAction(index) {
            if(isPlaceholderView) return;
            const anchors = document.querySelectorAll('.shard-anchor');
            if (isLocked && anchors[index].classList.contains('is-active')) resetCore(); else lockCore(index);
        }

        function lockCore(index) {
            isLocked = true; targetAngle = -index * degreePerNode; velocity = 0;
            const chap = syllabus[index]; const color = auras[chap.type] || '#ffffff';
            const currentVal = localData[chap.id] !== undefined ? localData[chap.id] : chap.defaultVal;

            arena.classList.replace('arena-idle', 'arena-locked'); arena.style.transform = `rotateY(0deg) rotateX(0deg)`; 
            document.querySelectorAll('.node-anchor').forEach(a => { a.classList.remove('is-active'); a.style.opacity = ''; a.style.filter = ''; });

            document.getElementById(`shard-anchor-${index}`).classList.add('is-active');
            document.getElementById(`mirror-anchor-${index}`).classList.add('is-active');

            coreRing.style.background = `conic-gradient(from 0deg, transparent 50%, ${color}40 80%, ${color} 100%)`;
            coreRing.style.opacity = '1'; coreRing.style.animationDuration = '2s';
            document.getElementById('auraBleed').style.background = `radial-gradient(circle at center, ${color}30 0%, var(--bg-void) 80%)`;
            
            coreMass.style.borderColor = color;
            coreMass.style.boxShadow = `0 0 100px ${color}70, inset 0 2px 15px rgba(255,255,255,0.05), inset 0 -10px 40px rgba(0,0,0,0.9)`;
            coreVal.innerText = currentVal + "%"; coreVal.style.color = color; coreVal.style.textShadow = `0 0 30px ${color}`; coreVal.style.transform = 'scale(1.1)';
            coreLbl.innerText = "ਲੈਕਚਰ ਜਾਰੀ ਹੈ"; coreLbl.style.color = color;
            playTick(0.25, 300); wakePhysicsLoop();
        }

        function resetCore() {
            isLocked = false; playTick(0.1, 100);
            arena.classList.replace('arena-locked', 'arena-idle');
            document.querySelectorAll('.node-anchor.is-active').forEach(a => a.classList.remove('is-active'));
            
            coreRing.style.background = `conic-gradient(from 0deg, transparent 60%, rgba(255,255,255,0.05) 80%, rgba(255,255,255,0.6) 100%)`;
            coreRing.style.opacity = '0.08'; coreRing.style.animationDuration = '4s';
            document.getElementById('auraBleed').style.background = `radial-gradient(circle at center, transparent 0%, var(--bg-void) 65%)`;
            
            coreMass.style.borderColor = 'rgba(255,255,255,0.06)';
            coreMass.style.boxShadow = `0 0 50px rgba(0,0,0,0.9), inset 0 2px 10px rgba(255,255,255,0.03), inset 0 -10px 40px rgba(0,0,0,0.8)`;
            updateGlobalSync(); 
            coreVal.style.color = 'var(--text-bold)'; coreVal.style.textShadow = `0 0 20px rgba(255,255,255,0.1)`; coreVal.style.transform = 'scale(1)';
            coreLbl.innerText = 'ਸਿਲੇਬਸ ਦੀ ਤਿਆਰੀ'; coreLbl.style.color = 'var(--text-dim)';
            wakePhysicsLoop();
        }

        function triggerGateway(e, color) {
            e.stopPropagation(); initAudio(); playTick(0.5, 600);
            gatewayCore.style.background = color; document.body.classList.add('gateway-active');
            setTimeout(() => { document.body.classList.remove('gateway-active'); resetCore(); }, 1800);
        }

        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') { toggleShareModal(false); if(isLocked) resetCore(); }
            if(!isLocked && !isPlaceholderView) {
                initAudio(); 
                if (e.key === 'ArrowRight') { targetAngle -= degreePerNode; velocity = 0; wakePhysicsLoop(); }
                if (e.key === 'ArrowLeft') { targetAngle += degreePerNode; velocity = 0; wakePhysicsLoop(); }
                if (e.key === 'Enter') handleNodeAction(getActiveIndex());
            }
        });

        window.addEventListener('resize', () => { wakePhysicsLoop(); });
        initDial();
    </script>
</body>
</html>